// Bawbel Scanner — Jenkins Pipeline example
// https://bawbel.io/docs/integrations/jenkins

pipeline {
    agent any

    stages {
        stage('Bawbel Security Scan') {
            steps {
                sh 'pip install "bawbel-scanner[all]"'
                sh 'bawbel scan . --recursive --fail-on-severity high --format sarif'
            }
            post {
                always {
                    archiveArtifacts(
                        artifacts: 'bawbel-results.sarif',
                        allowEmptyArchive: true
                    )
                }
            }
        }
    }
}

